{
  "kind": "collectionType",
  "collectionName": "programmes",
  "info": {
    "singularName": "programme",
    "pluralName": "programmes",
    "displayName": "programme"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "country": {
      "type": "string",
      "required": true
    },
    "duration": {
      "type": "string"
    },
    "requirements": {
      "type": "text"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "work",
        "travel",
        "internship"
      ]
    },
    "featured": {
      "type": "boolean"
    },
    "description": {
      "type": "blocks",
      "required": true
    },
    "applications": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::application.application",
      "mappedBy": "programme"
    }
  }
}
